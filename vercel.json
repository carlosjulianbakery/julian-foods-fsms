{
  "buildCommand": "rm -rf .next/cache && npx prisma generate && next build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/tasks/check-overdue",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/inventory/check-stock-levels",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/shipstation-sync",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/forms/monthly-cleaning/auto-submit",
      "schedule": "59 7 28-31 * *"
    }
  ]
}
