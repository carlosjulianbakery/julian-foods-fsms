generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERVISOR
  ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(SUPERVISOR)
  department    String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdForms      Form[]           @relation("FormCreator")
  submissions       FormSubmission[] @relation("Submitter")
  approvedSubmissions FormSubmission[] @relation("Approver")
  assignedTasks     Task[]           @relation("TaskAssignee")
  createdTasks      Task[]           @relation("TaskCreator")
  records           Record[]
  preOpInspections        PreOpInspection[]
  batchSheetSubmissions   BatchSheetSubmission[]
  createdBatchTemplates   BatchSheetTemplate[]
  createdProducts         Product[]
  dailyCleaningChecklists   DailyCleaningChecklist[]
  monthlyCleaningChecklists MonthlyCleaningChecklist[]
  receivingRecords          ReceivingRecord[]
  resolvedQuarantineRecords QuarantineRecord[]
  inventoryMovements        InventoryMovement[]
  cycleCounts               CycleCount[]
  formTemplates             FormTemplate[]
  initialStockEntries       InitialStockEntry[]
  createdTaskTemplates     TaskTemplate[] @relation("TaskTemplateCreator")
  completedTaskInstances   TaskInstance[] @relation("TaskInstanceCompleter")
  skippedTaskInstances     TaskInstance[] @relation("TaskInstanceSkipper")
  taskHistoryActions       TaskHistory[]  @relation("TaskHistoryPerformer")
  forecastExclusions            ForecastExclusion[]            @relation("ForecastExclusionCreator")
  stockAlertAcknowledgments     StockAlertAcknowledgment[]
  purchaseOrders                PurchaseOrder[]

  @@map("users")
}

model Form {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  fields      Json
  active      Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User   @relation("FormCreator", fields: [createdById], references: [id])
  createdById String

  submissions FormSubmission[]
  tasks       Task[]

  @@map("forms")
}

model FormSubmission {
  id        String           @id @default(cuid())
  formId    String
  data      Json
  status    SubmissionStatus @default(SUBMITTED)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  form        Form    @relation(fields: [formId], references: [id])
  submittedBy User    @relation("Submitter", fields: [submittedById], references: [id])
  submittedById String
  approvedBy  User?   @relation("Approver", fields: [approvedById], references: [id])
  approvedById String?

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id])

  @@map("form_submissions")
}

model Task {
  id          String         @id @default(cuid())
  title       String
  description String?
  status      TaskStatus     @default(PENDING)
  priority    TaskPriority   @default(MEDIUM)
  dueDate     DateTime
  completedAt DateTime?
  recurrence  RecurrenceType @default(NONE)
  location    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  formId   String?
  form     Form?   @relation(fields: [formId], references: [id])

  assignedTo   User   @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedToId String
  createdBy    User   @relation("TaskCreator", fields: [createdById], references: [id])
  createdById  String

  submissions FormSubmission[]

  @@map("tasks")
}

model Record {
  id          String   @id @default(cuid())
  title       String
  type        String
  description String?
  data        Json
  tags        String[]
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@map("records")
}

enum PreOpShift {
  AM
  PM
}

enum PreOpStatus {
  PASS
  FAIL
  PASS_WITH_ISSUES
}

model PreOpInspection {
  id                  String      @id @default(cuid())
  date                DateTime    @db.Date
  shift               PreOpShift
  status              PreOpStatus
  sections            Json
  correctiveAction    String?
  supervisorSignature String?
  submittedAt         DateTime    @default(now())

  submittedBy   User   @relation(fields: [submittedById], references: [id])
  submittedById String

  @@map("pre_op_inspections")
}

model BatchSheetTemplate {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  category              String?
  productCode           String?
  isActive              Boolean  @default(true)
  ingredients           Json
  packaging             Json
  ovensAvailable        Json
  calibrationWeights    Json
  ccpSettings           Json
  ccpNumSessions        Int      @default(3)
  ccpRequireTimestamp   Boolean  @default(false)
  endOfProductionFields   Json     @default("[]")
  primaryUnitName         String?
  hasInternalUnits        Boolean  @default(false)
  internalUnitName        String?
  internalUnitsPerPrimary Float?
  declaredAllergens       Json     @default("[]")
  hasExpirationDate       Boolean  @default(true)
  releaseChecklistItems   Json
  productId               String?
  legacyRecipe            Json?
  baseUnitName            String   @default("Bowl")
  baseUnitIsFinished      Boolean  @default(false)
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  createdBy   User                   @relation(fields: [createdById], references: [id])
  product     Product?               @relation(fields: [productId], references: [id])
  submissions BatchSheetSubmission[]

  @@map("batch_sheet_templates")
}

enum BatchSheetStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
  PASS
  FAIL
  PASS_WITH_ISSUES
}

model BatchSheetSubmission {
  id             String           @id @default(cuid())
  templateId     String
  templateName   String
  productionDate DateTime         @db.Date
  productionLot  String?
  expirationDate DateTime?        @db.Date
  shift          PreOpShift
  supervisorName String
  numEmployees   Int?
  status         BatchSheetStatus @default(IN_PROGRESS)
  section1          Json?
  section2_allergen Json?
  section3          Json?
  section4          Json?
  section5          Json?
  section6          Json?
  notes             String?
  lastSavedAt       DateTime?
  lastActiveSection Int?
  submittedAt    DateTime         @default(now())
  submittedById  String
  productId      String?
  recipeSnapshot Json?
  baseUnitName       String?
  baseUnitIsFinished Boolean?
  adminNotes              String?
  adminNotesUpdatedByName String?
  adminNotesUpdatedAt     DateTime?

  template    BatchSheetTemplate @relation(fields: [templateId], references: [id])
  submittedBy User               @relation(fields: [submittedById], references: [id])
  product     Product?           @relation(fields: [productId], references: [id])

  @@map("batch_sheet_submissions")
}

// ─── Daily Cleaning Checklist ───────────────────────────────────────────────

enum CleaningArea {
  MAIN
  BARS
}

enum CleaningStatus {
  COMPLETE
  INCOMPLETE
}

model DailyCleaningChecklist {
  id                  String         @id @default(cuid())
  area                CleaningArea
  date                DateTime       @db.Date
  allMachinesCleaned  Boolean        @default(false)
  prepToolsCleaned    Boolean        @default(false)
  floorsMoppedSwept   Boolean        @default(false)
  bakingTraysCleaned  Boolean        @default(false)
  foodSurfacesCleaned Boolean        @default(false)
  trashEmptied        Boolean        @default(false)
  items               Json?
  checkedBy           String
  notes               String?
  status              CleaningStatus
  submittedAt         DateTime       @default(now())
  submittedById       String

  submittedBy User @relation(fields: [submittedById], references: [id])

  @@map("daily_cleaning_checklists")
}

model MonthlyCleaningChecklist {
  id            String         @id @default(cuid())
  date          DateTime       @db.Date
  items         Json           @default("[]")
  checkedBy     String
  notes         String?
  status        CleaningStatus
  submittedAt   DateTime       @default(now())
  submittedById String

  submittedBy User @relation(fields: [submittedById], references: [id])

  @@map("monthly_cleaning_checklists")
}

// ─── Supplier Management ────────────────────────────────────────────────────

enum MaterialCategory {
  INGREDIENT
  PACKAGING
  OTHER
}

enum SupplierStatus {
  APPROVED
  EXPIRING_SOON
  EXPIRED
  PENDING
  INACTIVE
}

enum RequirementType {
  ONE_TIME
  ANNUAL
  PER_DELIVERY
}

model Material {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    MaterialCategory
  unit        String?
  isOrganic      Boolean          @default(false)
  isAllergen     Boolean          @default(false)
  allergens      Json?
  isGlutenFree   Boolean          @default(false)
  hasSpecialRisk Boolean          @default(false)
  specialRiskTypes Json?
  isActive    Boolean          @default(true)
  materialType    String   @default("raw")
  sourceProductId String?
  sourceProduct   Product? @relation("WipMaterialSource", fields: [sourceProductId], references: [id])
  isTemperatureSensitive Boolean @default(false)
  coaRequired            Boolean @default(false)
  minimumStockQuantity   Float?
  minimumStockUnit       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  suppliers          SupplierMaterial[]
  receivingRecords   ReceivingRecord[]
  inventoryLots      InventoryLot[]
  inventoryMovements InventoryMovement[]
  cycleCounts        CycleCount[]
  perDeliveryObligations PerDeliveryObligation[]
  initialStockEntries    InitialStockEntry[]
  stockAlertAcknowledgments StockAlertAcknowledgment[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("materials")
}

model Supplier {
  id               String         @id @default(cuid())
  name             String
  manufacturerName String?
  contactName      String?
  email            String?
  phone            String?
  address          String?
  notes            String?
  status           SupplierStatus @default(PENDING)
  isActive         Boolean        @default(true)
  supplierType     String         @default("ingredient")
  isSystemLocked   Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  materials          SupplierMaterial[]
  documents          SupplierDocument[]
  statusLogs         SupplierStatusLog[]
  receivingRecords   ReceivingRecord[]
  inventoryLots      InventoryLot[]
  brands             SupplierBrand[]
  perDeliveryObligations PerDeliveryObligation[]
  initialStockEntries    InitialStockEntry[]
  purchaseOrders         PurchaseOrder[]

  @@map("suppliers")
}

model SupplierBrand {
  id          String   @id @default(cuid())
  supplierId  String
  brandName   String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_brands")
}

model SupplierMaterial {
  id         String   @id @default(cuid())
  supplierId String
  materialId String
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([supplierId, materialId])
  @@map("supplier_materials")
}

model DocumentRequirement {
  id              String          @id @default(cuid())
  name            String
  description     String?
  requirementType RequirementType @default(ANNUAL)
  isRequired       Boolean         @default(true)
  isActive         Boolean         @default(true)
  sortOrder        Int             @default(0)
  isSystemLocked   Boolean         @default(false)
  triggerType      String?
  triggerCondition String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  documents              SupplierDocument[]
  perDeliveryObligations PerDeliveryObligation[]
  formTemplates          FormTemplate[]

  @@map("document_requirements")
}

model FormTemplate {
  id            String    @id @default(cuid())
  name          String
  description   String?
  filePath      String
  fileUrl       String
  fileName      String
  fileSize      Int?
  mimeType      String?
  requirementId String?
  uploadedById  String
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isActive      Boolean   @default(true)

  requirement  DocumentRequirement? @relation(fields: [requirementId], references: [id])
  uploadedBy   User                 @relation(fields: [uploadedById], references: [id])

  @@map("form_templates")
}

model SupplierDocument {
  id                String    @id @default(cuid())
  supplierId        String
  requirementId     String?
  fileName          String
  fileUrl           String
  fileSize          Int?
  mimeType          String?
  expiresAt         DateTime?
  uploadedAt        DateTime  @default(now())
  notes             String?
  receivingRecordId String?
  lotNumber         String?

  supplier              Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  requirement           DocumentRequirement? @relation(fields: [requirementId], references: [id])
  receivingRecord       ReceivingRecord?     @relation("SupDocReceivingRecord", fields: [receivingRecordId], references: [id])
  perDeliveryObligation PerDeliveryObligation?

  @@map("supplier_documents")
}

model PerDeliveryObligation {
  id                String    @id @default(cuid())
  supplierId        String
  materialId        String
  receivingRecordId String
  lotNumber         String
  requirementId     String
  status            String    @default("pending")
  documentId        String?   @unique
  createdAt         DateTime  @default(now())
  fulfilledAt       DateTime?

  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  material        Material            @relation(fields: [materialId], references: [id])
  receivingRecord ReceivingRecord     @relation(fields: [receivingRecordId], references: [id])
  requirement     DocumentRequirement @relation(fields: [requirementId], references: [id])
  document        SupplierDocument?   @relation(fields: [documentId], references: [id])

  @@unique([receivingRecordId, requirementId])
  @@map("per_delivery_obligations")
}

model SupplierStatusLog {
  id         String         @id @default(cuid())
  supplierId String
  status     SupplierStatus
  reason     String?
  createdAt  DateTime       @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_status_logs")
}

// ─── Products (master recipe registry) ──────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String?
  productCode String?
  description String?
  isActive    Boolean  @default(true)
  recipe      Json     @default("[]")
  // Computed fields — recalculated on every save
  allergenProfile  Json    @default("[]")
  isOrganic        Boolean @default(false)
  isGlutenFree     Boolean @default(false)
  supplierExposure Json    @default("[]")
  shelfLifeMonths  Int?
  presentations    Json    @default("[]")
  isWipMaterial    Boolean @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy          User                   @relation(fields: [createdById], references: [id])
  templates          BatchSheetTemplate[]
  submissions        BatchSheetSubmission[]
  wipMaterials       Material[]             @relation("WipMaterialSource")
  forecastExclusions ForecastExclusion[]

  @@map("products")
}

// ─── Purchasing ─────────────────────────────────────────────────────────────

model PurchaseOrder {
  id                      String    @id @default(cuid())
  poNumber                String    @unique
  supplierId              String
  supplierName            String    @default("")
  status                  String    @default("sent")
  sentDate                DateTime  @db.Date
  estimatedDeliveryDate   DateTime? @db.Date
  actualDeliveryDate      DateTime? @db.Date
  notes                   String?
  forecastPeriodFrom      DateTime? @db.Date
  forecastPeriodTo        DateTime? @db.Date
  createdById             String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  supplier         Supplier           @relation(fields: [supplierId], references: [id])
  createdBy        User               @relation(fields: [createdById], references: [id])
  items            PurchaseOrderItem[]
  receivingRecords ReceivingRecord[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  poId             String
  materialId       String
  materialName     String  @default("")
  qtyOrdered       Float
  unit             String  @default("lb")
  qtyReceived      Float   @default(0)
  qtyRemaining     Float   @default(0)
  isFullyReceived  Boolean @default(false)
  source           String  @default("direct")
  wipMaterialName  String?
  notes            String?

  po       PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  material Material      @relation(fields: [materialId], references: [id])

  @@map("purchase_order_items")
}

// ─── Receiving & Inventory ──────────────────────────────────────────────────

model ReceivingRecord {
  id                  String    @id @default(cuid())
  recordNumber        String    @unique
  date                DateTime  @db.Date
  timeReceived        String
  receivedById        String
  purchaseOrderNumber       String?
  materialId                String?
  materialName              String
  isUnregisteredMaterial    Boolean   @default(false)
  materialCategoryFreetext  String?
  supplierId                String?
  supplierName              String    @default("")
  brandId                   String?
  brandName                 String?
  lotNumber                 String
  quantityReceived          Float
  unit                      String
  expirationDate            DateTime? @db.Date
  conditionCheck            Json      @default("{}")
  coaRequired               Boolean   @default(false)
  coaReceived               Boolean?
  coaDocumentUrl            String?
  decision                  String
  submittedAt               DateTime  @default(now())
  notes                     String?

  poId             String?
  poNumber         String?

  receivedBy       User             @relation(fields: [receivedById], references: [id])
  material         Material?        @relation(fields: [materialId], references: [id])
  supplier         Supplier?        @relation(fields: [supplierId], references: [id])
  purchaseOrder    PurchaseOrder?   @relation(fields: [poId], references: [id])
  inventoryLot     InventoryLot?
  quarantineRecord QuarantineRecord?
  perDeliveryObligations PerDeliveryObligation[]
  supplierDocuments      SupplierDocument[]      @relation("SupDocReceivingRecord")

  @@map("receiving_records")
}

model QuarantineRecord {
  id                 String    @id @default(cuid())
  recordNumber       String    @unique
  receivingRecordId  String    @unique
  materialName       String
  supplierName       String
  lotNumber          String
  quantity           Float
  unit               String
  quarantineReason   String
  actionTaken        String
  quarantineLocation String?
  adminNotified      Boolean   @default(false)
  status             String    @default("open")
  resolutionNotes    String?
  resolvedById       String?
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())

  receivingRecord ReceivingRecord @relation(fields: [receivingRecordId], references: [id])
  resolvedBy      User?           @relation(fields: [resolvedById], references: [id])

  @@map("quarantine_records")
}

model InventoryLot {
  id                String    @id @default(cuid())
  materialId        String
  materialName      String
  supplierId        String?
  supplierName      String    @default("")
  brandId           String?
  brandName         String?
  lotNumber         String
  receivingRecordId String?   @unique
  quantityReceived  Float
  quantityRemaining Float
  unit              String
  receivedDate      DateTime  @db.Date
  expirationDate    DateTime? @db.Date
  status            String    @default("active")
  isConditional     Boolean   @default(false)
  conditionalNotes  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  material        Material          @relation(fields: [materialId], references: [id])
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  receivingRecord ReceivingRecord?  @relation(fields: [receivingRecordId], references: [id])
  movements       InventoryMovement[]
  cycleCounts     CycleCount[]
  initialStockEntry InitialStockEntry?

  @@map("inventory_lots")
}

model InventoryMovement {
  id              String   @id @default(cuid())
  inventoryLotId  String
  materialId      String
  materialName    String
  lotNumber       String
  movementType    String
  quantity        Float
  unit            String
  referenceType   String
  referenceId     String
  referenceNumber String
  quantityBefore  Float
  quantityAfter   Float
  performedById   String?
  performedAt     DateTime @default(now())
  notes           String?

  inventoryLot InventoryLot @relation(fields: [inventoryLotId], references: [id])
  material     Material     @relation(fields: [materialId], references: [id])
  performedBy  User?        @relation(fields: [performedById], references: [id])

  @@map("inventory_movements")
}

model CycleCount {
  id               String   @id @default(cuid())
  countDate        DateTime @db.Date
  materialId       String
  materialName     String
  inventoryLotId   String
  lotNumber        String
  quantityExpected            Float
  quantityCounted             Float
  quantityCountedOriginal     Float?
  quantityCountedOriginalUnit String?
  variance                    Float
  unit                        String
  reason                      String?
  reasonOther                 String?
  performedById               String
  performedAt                 DateTime @default(now())
  notes                       String?

  material     Material     @relation(fields: [materialId], references: [id])
  inventoryLot InventoryLot @relation(fields: [inventoryLotId], references: [id])
  performedBy  User         @relation(fields: [performedById], references: [id])

  @@map("cycle_counts")
}

model InitialStockEntry {
  id             String    @id @default(cuid())
  materialId     String
  materialName   String
  supplierId     String?
  supplierName   String    @default("")
  brandId        String?
  brandName      String?
  lotNumber      String
  quantity       Float
  unit           String
  expirationDate DateTime? @db.Date
  dateReceived   DateTime? @db.Date
  notes          String?
  inventoryLotId String    @unique
  enteredById    String
  enteredAt      DateTime  @default(now())

  material     Material     @relation(fields: [materialId], references: [id])
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])
  inventoryLot InventoryLot @relation(fields: [inventoryLotId], references: [id])
  enteredBy    User         @relation(fields: [enteredById], references: [id])

  @@map("initial_stock_entries")
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String
  userName  String
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─── Tasks System ────────────────────────────────────────────────────────────

enum TaskTemplateCategory {
  sanitation
  inspection
  production
  receiving_inventory
  documentation_compliance
  facility_maintenance
  administrative
}

enum TaskTemplatePriority {
  high
  normal
  low
}

enum TaskTemplateType {
  manual
  form_linked
}

enum TaskRecurrenceType {
  one_time
  daily
  weekly
  biweekly
  monthly
  every_2_months
  quarterly
  every_6_months
  annual
  custom
}

enum TaskInstanceStatus {
  pending
  complete
  overdue
  skipped
}

enum TaskHistoryAction {
  created
  completed
  skipped
  overdue
  next_instance_generated
}

model TaskTemplate {
  id               String               @id @default(cuid())
  title            String
  description      String?
  category         TaskTemplateCategory
  priority         TaskTemplatePriority @default(normal)
  assignedTo       Json
  taskType         TaskTemplateType     @default(manual)
  formLink         Json?
  recurrenceType   TaskRecurrenceType
  recurrenceConfig Json?
  firstDueDate     DateTime             @db.Date
  isActive         Boolean              @default(true)
  createdById      String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  createdBy User           @relation("TaskTemplateCreator", fields: [createdById], references: [id])
  instances TaskInstance[]

  @@map("task_templates")
}

model TaskInstance {
  id               String             @id @default(cuid())
  templateId       String
  title            String
  description      String?
  category         String
  priority         String
  assignedTo       Json
  taskType         String
  formLink         Json?
  dueDate          DateTime           @db.Date
  status           TaskInstanceStatus @default(pending)
  completedById    String?
  completedAt      DateTime?
  completionNote   String?
  skippedById      String?
  skippedAt        DateTime?
  skipReason       String?
  formSubmissionId String?
  instanceNumber   Int                @default(1)
  createdAt        DateTime           @default(now())

  template    TaskTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  completedBy User?         @relation("TaskInstanceCompleter", fields: [completedById], references: [id])
  skippedBy   User?         @relation("TaskInstanceSkipper", fields: [skippedById], references: [id])
  history     TaskHistory[]

  @@map("task_instances")
}

model TaskHistory {
  id            String            @id @default(cuid())
  instanceId    String
  action        TaskHistoryAction
  performedById String?
  performedAt   DateTime          @default(now())
  note          String?

  instance    TaskInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  performedBy User?        @relation("TaskHistoryPerformer", fields: [performedById], references: [id])

  @@map("task_history")
}

// ─── Stock Alert Acknowledgments ─────────────────────────────────────────────

model StockAlertAcknowledgment {
  id               String    @id @default(cuid())
  materialId       String
  alertType        String
  acknowledgedById String
  acknowledgedAt   DateTime  @default(now())
  note             String?
  isResolved       Boolean   @default(false)
  resolvedAt       DateTime?
  expiresAt        DateTime?

  material       Material @relation(fields: [materialId], references: [id])
  acknowledgedBy User     @relation(fields: [acknowledgedById], references: [id])

  @@map("stock_alert_acknowledgments")
}

// ─── Forecast Exclusions ────────────────────────────────────────────────────

model ForecastExclusion {
  id             String   @id @default(cuid())
  excludedById   String
  excludedAt     DateTime @default(now())
  productionDate DateTime @db.Date
  productName    String
  productId      String?
  baseUnitCount  Int?
  reason         String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  excludedBy User     @relation("ForecastExclusionCreator", fields: [excludedById], references: [id])
  product    Product? @relation(fields: [productId], references: [id])

  @@map("forecast_exclusions")
}
